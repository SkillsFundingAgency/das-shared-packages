          "Name",
          "Created",
          "Updated"
        ],
        "type": "string"
      },
      "DasRequestRuleSet": {
        "type": "integer",
        "format": "int64",
        "x-enumFlags": true,
        "x-enumNames": [
          "None",
          "Name",
          "Description",
          "Status",
          "All"
        ],
        "enum": [
          0,
          1,
          2,
          4,
          -1
        ],
        "description": "Flags enum \u2014 pass comma-separated names (e.g. Name,Description)."
      },
      "PostDasRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PutDasRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
